import React, { useState, useEffect } from 'react';
import { auth } from './firebase';
import { onAuthStateChanged, User } from 'firebase/auth';
import { syncData } from './dataService';
import { Invoice, ProformaInvoice, Quotation, Customer, Item, Company } from './types';
import Auth from './components/Auth';
import LandingPage from './components/LandingPage';
import Sidebar from './components/Sidebar';
import Dashboard from './components/Dashboard';
import InvoiceModule from './components/InvoiceModule';
import ProformaModule from './components/ProformaModule';
import ItemModule from './components/ItemModule';
import CustomerModule from './components/CustomerModule';
import CompanyModule from './components/CompanyModule';
import BackupModule from './components/BackupModule';
import { Loader2, Menu } from 'lucide-react';

export default function App() {
  const [user, setUser] = useState<User | null>(null);
  const [loading, setLoading] = useState(true);
  const [activeTab, setActiveTab] = useState('dashboard');
  const [showAuth, setShowAuth] = useState(false);
  const [isSidebarOpen, setIsSidebarOpen] = useState(false);
  
  // Data State
  const [invoices, setInvoices] = useState<Invoice[]>([]);
  const [pis, setPIs] = useState<ProformaInvoice[]>([]);
  const [quotations, setQuotations] = useState<Quotation[]>([]);
  const [customers, setCustomers] = useState<Customer[]>([]);
  const [items, setItems] = useState<Item[]>([]);
  const [company, setCompany] = useState<Company | null>(null);
  const [syncStatus, setSyncStatus] = useState<'synced' | 'syncing' | 'error'>('synced');

  useEffect(() => {
    const unsub = onAuthStateChanged(auth, (u) => {
      setUser(u);
      setLoading(false);
    });
    return unsub;
  }, []);

  useEffect(() => {
    if (user) {
      setSyncStatus('syncing');
      const unsubSync = syncData(
        user.uid,
        setInvoices,
        setPIs,
        setQuotations,
        setCustomers,
        setItems,
        setCompany
      );
      setSyncStatus('synced');
      return unsubSync;
    }
  }, [user]);

  if (loading) {
    return (
      <div className="min-h-screen bg-[#0d1018] flex items-center justify-center">
        <Loader2 className="w-8 h-8 text-[#6c63ff] animate-spin" />
      </div>
    );
  }

  if (!user) {
    if (showAuth) {
      return <Auth onBack={() => setShowAuth(false)} />;
    }
    return <LandingPage onGetStarted={() => setShowAuth(true)} />;
  }

  const renderContent = () => {
    switch (activeTab) {
      case 'dashboard':
        return <Dashboard invoices={invoices} piCount={pis.length} itemCount={items.length} customerCount={customers.length} />;
      case 'invoices':
        return <InvoiceModule invoices={invoices.filter(inv => inv.docType !== 'credit')} customers={customers} items={items} company={company} userId={user.uid} />;
      case 'proforma':
        return <ProformaModule pis={pis} customers={customers} items={items} company={company} userId={user.uid} />;
      case 'quotations':
        return <InvoiceModule invoices={quotations as any} customers={customers} items={items} company={company} userId={user.uid} isQuotation />;
      case 'credit-notes':
        return <InvoiceModule invoices={invoices.filter(inv => inv.docType === 'credit')} customers={customers} items={items} company={company} userId={user.uid} isCreditNote />;
      case 'items':
        return <ItemModule items={items} userId={user.uid} />;
      case 'customers':
        return <CustomerModule customers={customers} userId={user.uid} />;
      case 'company':
        return <CompanyModule company={company} userId={user.uid} />;
      case 'backup':
        return <BackupModule invoices={invoices} pis={pis} customers={customers} items={items} company={company} userId={user.uid} />;
      default:
        return <Dashboard invoices={invoices} piCount={pis.length} itemCount={items.length} customerCount={customers.length} />;
    }
  };

  return (
    <div className="min-h-screen bg-[#0d1018] font-sans text-[#e2e5f0]">
      <Sidebar 
        activeTab={activeTab} 
        setActiveTab={setActiveTab} 
        companyName={company?.name} 
        gstin={company?.gstin}
        syncStatus={syncStatus}
        isOpen={isSidebarOpen}
        onClose={() => setIsSidebarOpen(false)}
      />
      <main className="lg:pl-64 min-h-screen transition-all">
        <header className="h-16 border-b border-[#252b3b] flex items-center justify-between px-4 lg:px-8 sticky top-0 bg-[#0d1018]/80 backdrop-blur-md z-10">
          <div className="flex items-center gap-3">
            <button 
              onClick={() => setIsSidebarOpen(true)}
              className="lg:hidden p-2 text-[#8892ab] hover:text-[#e2e5f0] hover:bg-[#1a1f2e] rounded-lg transition-colors"
            >
              <Menu className="w-5 h-5" />
            </button>
            <h2 className="text-lg font-bold capitalize">{activeTab.replace('-', ' ')}</h2>
          </div>
          <div className="flex items-center gap-4">
            {/* Header Actions */}
          </div>
        </header>
        <div className="p-4 lg:p-8 max-w-7xl mx-auto">
          {renderContent()}
        </div>
      </main>
    </div>
  );
}
